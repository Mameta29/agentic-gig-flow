{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "WebFetch",
      "WebSearch",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(tsx:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(az:*)",
      "Bash(func:*)",
      "Bash(docker:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(echo:*)",
      "Bash(test:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(openssl:*)",
      "Bash(tree:*)",
      "Bash(pwd)",
      "Bash(true)",
      "Bash(false)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(sudo rm:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(az group delete:*)",
      "Read(.env)",
      "Read(**/local.settings.json)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*wallet-pk*)",
      "Read(**/*private-key*)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "alwaysThinkingEnabled": false,
  "effortLevel": "medium"
}
