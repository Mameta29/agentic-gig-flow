# =====================================================
# Agentic Gig-Flow — environment variables (shared)
# =====================================================
# Copy to .env and fill in. Never commit .env.

# ----- Azure -----
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
RESOURCE_GROUP=rg-gigflow-prod
LOCATION=japaneast

# ----- Cosmos DB -----
COSMOS_ENDPOINT=https://cosmos-gigflow-xxxxxx.documents.azure.com:443/
COSMOS_DATABASE=gigflow

# ----- Key Vault -----
KEY_VAULT_NAME=kv-gigflow-xxxxxx

# ----- Azure OpenAI / Foundry -----
AZURE_OPENAI_ENDPOINT=https://aoai-gigflow-xxxxxx.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# ----- Polygon / JPYC -----
POLYGON_RPC=https://polygon-rpc.com
JPYC_ADDRESS=0x431D5dfF03120AFA4bDf332c61A6e1766eF37BDB
WALLET_PK_SECRET_NAME=wallet-pk

# ----- GitHub -----
GITHUB_PAT_SECRET_NAME=github-pat
GITHUB_WEBHOOK_SECRET_NAME=github-webhook-secret

# ----- Entra ID -----
FUNCTIONS_APP_AUDIENCE=api://gigflow-functions
MCP_APP_AUDIENCE=api://gigflow-mcp
FABRIC_APP_AUDIENCE=api://gigflow-fabric
DASHBOARD_APP_ID=
FUNCTIONS_APP_ID=
MCP_APP_ID=
BOT_APP_ID=
BOT_CLIENT_SECRET_NAME=bot-client-secret

# ----- URLs -----
DASHBOARD_URL=https://dashboard-gigflow-xxxxxx.azurecontainerapps.io
MCP_URL=https://mcp-gigflow-xxxxxx.azurecontainerapps.io
POWER_BI_REPORT_URL=https://app.powerbi.com/groups/.../reports/...

# ----- Application Insights -----
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ----- Dashboard (NextAuth) -----
AUTH_SECRET=
AUTH_ENTRA_CLIENT_ID=
AUTH_ENTRA_CLIENT_SECRET=
