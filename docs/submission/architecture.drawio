  <diagram name="Agentic-Gig-Flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title block -->
        <mxCell id="title" value="Agentic Gig-Flow &#8212; Microsoft 完結アーキテクチャ" style="text;html=1;fontSize=22;fontStyle=1;align=left;verticalAlign=middle;fontColor=#0078D4;" vertex="1" parent="1">
