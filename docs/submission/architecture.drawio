        <mxCell id="subtitle" value="4ユーザー × 4入口 → 共通の自律エンジン（4 Agent / Foundry gpt-4o）→ JPYC決済 / Cosmos記録" style="text;html=1;fontSize=13;align=left;verticalAlign=middle;fontColor=#5F6368;" vertex="1" parent="1">
